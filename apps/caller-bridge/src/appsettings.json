{
  "Bridge": {
    "ApiBaseUrl": "https://your-domain/api",
    "BridgeToken": "REPLACE_ME",
    "TenantId": "REPLACE_ME",
    "LineCount": 1,
    "UseMockDevice": false,
    "MockEmitEverySeconds": null
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/caller-bridge-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "shared": true
        }
      }
    ]
  }
}
