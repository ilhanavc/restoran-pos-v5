DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pos_dev
TENANT_ID=00000000-0000-7000-8000-000000000001
JWT_ACCESS_SECRET=change-me-min-32-chars-random-secret
NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:5173
BCRYPT_COST=12
# ADR-016 §11 — Caller bridge shared secret (X-Bridge-Token header).
# Prod'da min 32 karakter random; dev'de opsiyonel (tanımsızsa bridge
# endpoint fail-closed 401 döner).
BRIDGE_TOKEN=replace-with-32-char-secret
