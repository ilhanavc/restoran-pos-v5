# Local development environment — copy to .env.local and fill in values
# .env.local is gitignored, never commit real credentials

# PostgreSQL 17 (docker-compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pos_dev
MIGRATOR_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pos_dev
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pos_dev
CRON_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pos_dev

# API
JWT_SECRET=dev-secret-change-in-production
NODE_ENV=development
