{
  "name": "@restoran-pos/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22.11.0 <23.0.0" },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "migrate": "node-pg-migrate -m migrations up",
    "codegen": "kysely-codegen --url $DATABASE_URL --out-file src/generated.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: ok'",
    "test": "vitest run"
  },
  "dependencies": {
    "kysely": "^0.27.0",
    "node-pg-migrate": "^7.0.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "kysely-codegen": "^0.17.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
